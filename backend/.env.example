# ─────────────────────────────────────────────
# AI Disease Risk Prediction — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# PostgreSQL — Replace with your actual connection string
DATABASE_URL=postgresql://username:password@localhost:5432/disease_risk_db

# Python ML API
ML_API_URL=http://localhost:5001

# Frontend URL (for CORS — use * for dev)
FRONTEND_URL=*

# SMTP (for email reports) — Gmail example
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
